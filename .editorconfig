root = true

[{*.fs,*.json}]
indent_style = space
indent_size = 4
end_of_line = unset
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[{{Directory.Build.props,Directory.Packages.props},*.{fsproj,csproj,xml}}]
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

type User = {
    Id: int64
    AccessHash: int64
    FirstName: string
} with

    static member ConstructorId: uint32 = 559694904u

    static member Serialize(writer: TlWriteBuffer, value: User) : unit =
        writer.WriteConstructorId(559694904u)
        writer.WriteInt64(value.Id)
        writer.WriteInt64(value.AccessHash)
        writer.WriteString(value.FirstName)

    static member Deserialize(reader: TlReadBuffer) : User =
        let _cid = reader.ReadConstructorId()
        let id = reader.ReadInt64()
        let accessHash = reader.ReadInt64()
        let firstName = reader.ReadString()

        {
            Id = id
            AccessHash = accessHash
            FirstName = firstName
        }